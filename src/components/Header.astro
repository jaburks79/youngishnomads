---
---
<header>
  <nav>
    <a href="/" class="logo">
      <span class="logo-main">Youngish</span><span class="logo-accent">Nomads</span>
    </a>
    <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/blog">Travel Stories</a></li>
      <li><a href="/about">Our Story</a></li>
    </ul>
  </nav>
</header>

<style>
  header {
    background: var(--forest);
    padding: 1.25rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    text-decoration: none;
  }

  .logo-main {
    color: var(--cream);
  }

  .logo-accent {
    color: #A8C5A0;
  }

  ul {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  ul a {
    color: var(--cream);
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    opacity: 0.85;
    transition: opacity 0.2s;
  }

  ul a:hover {
    opacity: 1;
    color: #A8C5A0;
  }
</style>